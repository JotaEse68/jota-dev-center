{
  "name": "jota-dev-center",
  "version": "1.1.0",
  "private": true,
  "description": "Panel local profesional para gestionar proyectos con el flujo PowerShell -> Claude Code -> GitHub -> Vercel",
  "type": "module",
  "main": "app-build/main.cjs",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cross-env JOTA_CLI=1 tsx watch server/index.ts",
    "client:dev": "vite --host 127.0.0.1 --port 3333",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production JOTA_CLI=1 tsx server/index.ts",
    "shortcut": "powershell -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "electron:bundle": "esbuild electron/main.ts --bundle --platform=node --target=node18 --format=cjs --outfile=app-build/main.cjs --external:electron --external:fsevents",
    "electron:build": "npm run build && npm run electron:bundle",
    "app": "npm run electron:build && electron app-build/main.cjs",
    "dist": "npm run electron:build && electron-builder",
    "dist:win": "npm run electron:build && electron-builder --win",
    "dist:mac": "npm run electron:build && electron-builder --mac",
    "dist:linux": "npm run electron:build && electron-builder --linux"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cross-env": "^7.0.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.jota.devcenter",
    "productName": "Jota Dev Center",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "app-build/**/*",
      "dist/**/*",
      "data/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "maintainer": "JotaEse68"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jota Dev Center"
    }
  }
}
